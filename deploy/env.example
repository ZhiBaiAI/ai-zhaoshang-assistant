POSTGRES_DB=ai_zhaoshang
POSTGRES_USER=ai_zhaoshang
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

API_PORT=3001
API_TOKEN=change_me
DATABASE_URL=postgres://ai_zhaoshang:change_me@127.0.0.1:5432/ai_zhaoshang

EMBEDDING_ENDPOINT=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=deepseek-chat

REPLY_MODE=readonly

# Prefer Feishu Open Platform for production notifications.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_NOTIFY_RECEIVE_ID=
FEISHU_NOTIFY_RECEIVE_ID_TYPE=chat_id
FEISHU_BITABLE_APP_TOKEN=
FEISHU_LEADS_TABLE_ID=

# Fallback simple bot webhook.
FEISHU_WEBHOOK_URL=

# Optional extra notification channels.
WECOM_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# Douyin local agent.
API_BASE_URL=http://127.0.0.1:3001
DOUYIN_PROJECT_ID=project-1
DOUYIN_AGENT_ID=douyin-agent-1
DOUYIN_SEND_ENABLED=0
DOUYIN_SEND_DRY_RUN=1
DOUYIN_SEND_LIMIT=5

# Worker polling pending reply tasks through api-service.
WORKER_API_BASE_URL=http://127.0.0.1:3001
WORKER_PROJECT_ID=project-1
WORKER_API_TASKS=1
WORKER_INTERVAL_MS=10000
WORKER_BATCH_SIZE=5
WORKER_REVIEW_BATCH_SIZE=5
WORKER_ONCE=0
WORKER_FEISHU_SYNC=0
WORKER_REVIEW_REPORTS=0
WORKER_DINGTALK_A1_SYNC=0
DINGTALK_A1_BASE_URL=https://api.dingtalk.com
DINGTALK_A1_ACCESS_TOKEN=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_A1_SN_LIST=
DINGTALK_A1_DEVICE_TYPE=A1
DINGTALK_A1_LOOKBACK_MS=86400000
DINGTALK_A1_MAX_RESULTS=20
DINGTALK_A1_DATA_DIR=data/dingtalk-a1
DINGTALK_A1_DOWNLOAD_AUDIO=0

# Dianping review agent.
